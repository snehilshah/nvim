{
  "runtime": {
    "version": "LuaJIT",
    "path": ["?.lua", "?/init.lua", "lua/?.lua", "lua/?/init.lua"]
  },
  "workspace": {
    "checkThirdParty": false,
    "library": [
      "$VIMRUNTIME/lua",
      "${3rd}/luv/library",
      "lua",
      "$XDG_DATA_HOME/nvim/lazy/LuaSnip/lua",
      "$XDG_DATA_HOME/nvim/lazy/blink.cmp/lua",
      "$XDG_DATA_HOME/nvim/lazy/flash.nvim/lua",
      "$XDG_DATA_HOME/nvim/lazy/fzf-lua/lua",
      "$XDG_DATA_HOME/nvim/lazy/gitlinker.nvim/lua",
      "$XDG_DATA_HOME/nvim/lazy/grug-far.nvim/lua",
      "$XDG_DATA_HOME/nvim/lazy/lazy.nvim/lua",
      "$XDG_DATA_HOME/nvim/lazy/mini.ai/lua",
      "$XDG_DATA_HOME/nvim/lazy/mini.bufremove/lua",
      "$XDG_DATA_HOME/nvim/lazy/mini.clue/lua",
      "$XDG_DATA_HOME/nvim/lazy/mini.files/lua",
      "$XDG_DATA_HOME/nvim/lazy/mini.splitjoin/lua",
      "$XDG_DATA_HOME/nvim/lazy/neocodeium/lua",
      "$XDG_DATA_HOME/nvim/lazy/nvim-autopairs/lua",
      "$XDG_DATA_HOME/nvim/lazy/nvim-treesitter-context/lua"
    ]
  },
  "diagnostics.globals": ["vim", "MiniIcons"]
}
